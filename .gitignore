# Folders and files to ignore for an Android project

# Built application files
*.apk
*.aab

# Files for the ART/Dalvik VM
*.dex

# Built output folder
/build/

# Generated files
/app/build/

# Local configuration file (important!)
/local.properties

# IDE-specific files
.idea/
.gradle/
captures/
*.iml
.cxx/

# Keystore files
*.jks
*.keystore

# Crashlytics files
com_crashlytics_export_strings.xml

# Google Services (if you add them later)
google-services.json
